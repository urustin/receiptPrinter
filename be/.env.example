# JWT secret key (random string)
SECRET_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REDIRECT_URI=https://your-domain.com/auth/callback

# Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=

# TICKET=SUBTASK → create subtask under JIRA_PARENT_KEY (default)
# TICKET=TASK    → create independent task in JIRA_PROJECT_KEY (appears in board TO DO)
TICKET=SUBTASK
JIRA_PARENT_KEY=PROJ-123     # required when TICKET=SUBTASK
JIRA_PROJECT_KEY=PROJ        # required when TICKET=TASK (or auto-derived from JIRA_PARENT_KEY)
